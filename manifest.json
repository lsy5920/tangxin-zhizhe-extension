{
  "manifest_version": 3,
  "name": "糖心志者",
  "version": "2.0.4",
  "description": "账号池管理、播放资源观测、播放详情获取和视频下载任务管理工具。",
  "permissions": [
    "storage",
    "downloads",
    "offscreen"
  ],
  "host_permissions": [
    "https://txh068.com/*",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://txh068.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "糖心志者"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "nav_guard.js",
        "page_hook.js",
        "page_probe.js",
        "display_patch.js",
        "README.md",
        "update.json",
        "assets/hero-console.png",
        "assets/empty-state.png",
        "assets/icon-sheet.png",
        "assets/ui-layout-pc.png",
        "assets/ui-layout-mobile.png",
        "assets/page-illustrations.png",
        "assets/nav-icons.png",
        "assets/nav-icons-square.png",
        "assets/nav-icon-overview.png",
        "assets/nav-icon-trace.png",
        "assets/nav-icon-permission.png",
        "assets/nav-icon-fullplay.png",
        "assets/nav-icon-downloads.png",
        "assets/nav-icon-accounts.png",
        "assets/nav-icon-compare.png",
        "assets/nav-icon-tools.png",
        "assets/floating-ball.png",
        "assets/flow-badge-bg.png",
        "assets/mobile-texture.png",
        "vendor/mux-7.0.0.min.js"
      ],
      "matches": [
        "https://txh068.com/*"
      ]
    }
  ]
}
