{
  "manifest_version": 3,
  "name": "糖心志者",
  "version": "1.3.1",
  "description": "账号池管理、播放资源观测、播放详情获取和视频下载任务管理工具。",
  "permissions": [
    "storage",
    "downloads",
    "offscreen"
  ],
  "host_permissions": [
    "https://txh068.com/*",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://txh068.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "糖心志者"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "nav_guard.js",
        "page_hook.js",
        "page_probe.js",
        "display_patch.js",
        "README.md",
        "vendor/mux-7.0.0.min.js"
      ],
      "matches": [
        "https://txh068.com/*"
      ]
    }
  ]
}
